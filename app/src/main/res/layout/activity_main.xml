<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page_gradient"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnImport"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="导入课表"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_input_add"
            android:tint="#FFFFFFFF" />

        <ImageButton
            android:id="@+id/btnSetFirstWeek"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="设置第一周日期"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_my_calendar"
            android:tint="#FFFFFFFF" />

        <ImageButton
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="清空"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="#FFFFFFFF" />

        <ImageButton
            android:id="@+id/btnGuide"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="操作指南"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_help"
            android:tint="#FFFFFFFF" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:background="@drawable/bg_timetable_panel"
        android:padding="8dp">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="horizontal">

            <ScrollView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:scrollbars="vertical">

                <LinearLayout
                    android:id="@+id/timetableGrid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>
        </HorizontalScrollView>
    </FrameLayout>

</LinearLayout>
